# ──────────────────────────────────────────────────────
# Doings Brief – Environment Variables
# Kopiera till .env.local för lokal utveckling
# Sätt dessa i Vercel Dashboard → Settings → Environment Variables
# ──────────────────────────────────────────────────────

# PIN-kod som kunden använder för att öppna briefen
BRIEF_PIN_CODE=1234

# Berget AI API-nyckel (samma som i mötesassistenten)
# Används för KB-Whisper transkription
BERGET_API_KEY=your_berget_api_key_here

# Resend API-nyckel för e-post
# Skaffa på: https://resend.com
RESEND_API_KEY=your_resend_api_key_here

# Supabase-projektets URL och publika anon-nyckel
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Server-only service role key för admin-operationer och säkra API-routes
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Publik app-URL som används i mail och redirect-flöden
NEXT_PUBLIC_SITE_URL=https://doings-brief.vercel.app

# Playwright smoke test för Word-export
DOINGS_BRIEF_BASE_URL=https://doings-brief.vercel.app
DOINGS_BRIEF_TEST_EMAIL=consultant@example.com
DOINGS_BRIEF_TEST_PASSWORD=your_test_password_here
# Valfritt: ange exakt svarssida om du vill undvika att ta första "Se svar"
# DOINGS_BRIEF_RESPONSE_URL=https://doings-brief.vercel.app/dashboard/briefs/your-session-id

# Playwright smoke test för batchutskick
# Skapar ett unikt företag och skickar ett multi-mottagarutskick till example.com-adresser
# med samma testkonto som ovan

# Playwright smoke test för AI-sammanfattning
# Återanvänder samma testkonto och kan använda samma DOINGS_BRIEF_RESPONSE_URL

# Avsändaradress (måste vara verifierad domän i Resend)
FROM_EMAIL=brief@doingsclients.se

# Valfri hemlighet för session-token (generera med: openssl rand -hex 32)
NEXTAUTH_SECRET=your_random_secret_here
